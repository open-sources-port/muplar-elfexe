# Linux syscall dispatch table entries
#
# Copyright 2026 elfuse contributors
# SPDX-License-Identifier: Apache-2.0
#
# Format:
#   SYS_<name> sc_<wrapper> <extra>
#
# Comment lines beginning with a single "#" become section comments in the
# generated header. Blank lines are preserved as visual separators.

# I/O: read, write, seek, splice
SYS_eventfd2 sc_eventfd2 0
SYS_epoll_create1 sc_epoll_create1 0
